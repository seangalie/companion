# ------------------
# Visual Studio Code
# ------------------

# Fix syntax highlighting on GitHub to allow comments
.vscode/*.json linguist-language=JSON-with-Comments

# ----------------
# Git Line Endings
# ----------------

# Set default behaviour to automatically normalize line endings.
* text=auto

# Force bash scripts to always use LF line endings so that if a repo is accessed
# in Unix via a file share from Windows, the scripts will work.
*.sh    text eol=lf
*.bash  text eol=lf
*.zsh   text eol=lf

# Force PowerShell & batch scripts to always use CRLF line endings so that if a
# repo is accessed in Windows via a share from Linux, the scripts will work.
*.ps1   text eol=crlf
*.{cmd,[cC][mM][dD]}    text eol=crlf
*.{bat,[bB][aA][tT]}    text eol=crlf

# -----------------
# Git File Handling
# -----------------

# Text files
*.txt   text eol=lf
*.md    text eol=lf diff=markdown linguist-detectable
*.htm   text eol=lf diff=html
*.html  text eol=lf diff=html
*.css   text eol=lf diff=css
*.xml   text eol=lf diff=xml
*.json  text eol=lf diff=json
*.js    text eol=lf diff=javascript
*.ts    text eol=lf diff=typescript
*.jsx   text eol=lf diff=javascript
*.tsx   text eol=lf diff=typescript
*.php   text eol=lf diff=php
*.sql   text eol=lf diff=sql
*.csv   text eol=crlf
*.toml  text
*.yaml  text eol=lf
*.yml   text eol=lf

# Other Assets
*.svg   text

# Configs
package.json        text eol=lf
package-lock.json   text eol=lf -diff
pnpm-lock.yaml      text eol=lf -diff

# These files are text and should have LF line endings on checkout
.gitattributes  text
.gitignore      text
.gitmodules     text

# ---------------------------
# Git Large File System (LFS)
# ---------------------------

# Archives
*.7z    filter=lfs diff=lfs merge=lfs -text
*.bz    filter=lfs diff=lfs merge=lfs -text
*.bz2   filter=lfs diff=lfs merge=lfs -text
*.bzip2 filter=lfs diff=lfs merge=lfs -text
*.gz    filter=lfs diff=lfs merge=lfs -text
*.rar   filter=lfs diff=lfs merge=lfs -text
*.tar   filter=lfs diff=lfs merge=lfs -text
*.tgz   filter=lfs diff=lfs merge=lfs -text
*.txz   filter=lfs diff=lfs merge=lfs -text
*.xz    filter=lfs diff=lfs merge=lfs -text
*.zip   filter=lfs diff=lfs merge=lfs -text

# Documents
*.pdf   filter=lfs diff=lfs merge=lfs -text

# Images
*.gif   filter=lfs diff=lfs merge=lfs -text
*.ico   filter=lfs diff=lfs merge=lfs -text
*.jpg   filter=lfs diff=lfs merge=lfs -text
*.jpeg  filter=lfs diff=lfs merge=lfs -text
*.png   filter=lfs diff=lfs merge=lfs -text
*.psd   filter=lfs diff=lfs merge=lfs -text
*.webp  filter=lfs diff=lfs merge=lfs -text

# Fonts
*.eot   filter=lfs diff=lfs merge=lfs -text
*.otf   filter=lfs diff=lfs merge=lfs -text
*.ttf   filter=lfs diff=lfs merge=lfs -text
*.woff  filter=lfs diff=lfs merge=lfs -text
*.woff2 filter=lfs diff=lfs merge=lfs -text

# Text files where line endings should be preserved
*.patch -text

# Other
*.exe   filter=lfs diff=lfs merge=lfs -text

# Exclude files from exporting
.gitattributes  export-ignore
.gitignore      export-ignore
.gitkeep        export-ignore
