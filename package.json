{
  "name": "@seangalie/companion",
  "version": "0.1.4",
  "description": "A macOS update console that packages routine maintenance commands into a shareable Node-powered TUI.",
  "keywords": [
    "cli",
    "tui",
    "macos",
    "homebrew",
    "npm",
    "automation",
    "updates"
  ],
  "homepage": "https://github.com/seangalie/companion#readme",
  "bugs": {
    "url": "https://github.com/seangalie/companion/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seangalie/companion.git"
  },
  "license": "Apache-2.0",
  "author": "Sean Galie",
  "type": "commonjs",
  "main": "index.js",
  "bin": {
    "companion": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "VERSION"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "prepare": "npm run build"
  },
  "dependencies": {
    "blessed": "^0.1.81"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.25",
    "@types/node": "^24.7.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  }
}
